# Copy this file to ".env" and fill in your key.

# Provider: "groq" (cloud, free tier, ~2s, vision) | "openai" (cloud, paid, vision)
# | "cerebras" (cloud, very fast, TEXT-ONLY — use for extractFromText/OCR path only,
# not image upload) | "ollama" (local, slow)
PROVIDER=groq

# For PROVIDER=groq (free tier). https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# For PROVIDER=openai (paid). Get a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_key_here

# For PROVIDER=cerebras (free tier, text-only). https://cloud.cerebras.ai/
# CEREBRAS_API_KEY=csk-your_key_here

# Optional overrides
# OPENAI_MODEL=gpt-4o-mini
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# CEREBRAS_MODEL=llama-3.3-70b
# OLLAMA_MODEL=gemma3:4b
